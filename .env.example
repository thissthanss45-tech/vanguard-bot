# Required
TELEGRAM_BOT_TOKEN=your_telegram_token

# AI Providers (optional, fallback chain is used)
DEEPSEEK_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Runtime
REQUEST_TIMEOUT_SEC=45
MARKET_CACHE_TTL_SEC=90
NEWS_CACHE_TTL_SEC=120
AI_PROVIDER_TIMEOUT_SEC=22
AI_TOTAL_BUDGET_SEC=24
DEEPSEEK_STRICT=true
DEEPSEEK_FAST_PROMPT=true
DEEPSEEK_REQUIRE_SUCCESS=true
DEEPSEEK_MAX_TOKENS=280
CACHE_BACKEND=redis
REDIS_URL=redis://redis:6379/0

# Security
AUTH_WHITELIST=

# Webhook mode (production)
USE_WEBHOOK=true
WEBHOOK_URL=https://your-domain.example.com
WEBHOOK_PATH=/telegram
WEBHOOK_PORT=8080

# Watchdog / alerts
WATCHDOG_INTERVAL_SEC=180
ADMIN_CHAT_ID=

# ── SaaS API ──────────────────────────────────────────────────────────────────
# База данных (SQLite по умолчанию, PostgreSQL для прода)
API_DATABASE_URL=sqlite:///./vanguard_api.db
# Мастер-ключ для создания других ключей (установи случайную строку!)
API_ADMIN_KEY=changeme-replace-with-random-secret
# CORS: через запятую, или * для всех
API_CORS_ORIGINS=*

# Stripe (опционально, для автоматической активации подписок)
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_secret
STRIPE_API_KEY=sk_live_replace_with_real_key
STRIPE_PRICE_PRO=price_replace_with_pro_price_id
STRIPE_PRICE_ENTERPRISE=price_replace_with_enterprise_price_id
