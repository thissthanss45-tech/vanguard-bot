# ─────────────────────────────────────────────────────────────────────────────
#  ШАБЛОН СЕКРЕТА — не коммитить с реальными значениями!
#
#  Заполнить и применить:
#    cp k8s/bot/secret.yaml.example /tmp/vanguard-secret.yaml
#    # отредактировать /tmp/vanguard-secret.yaml
#    kubectl apply -f /tmp/vanguard-secret.yaml
#    rm /tmp/vanguard-secret.yaml
#
#  Или использовать External Secrets Operator / Vault / Sealed Secrets.
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: vanguard-secret
  namespace: vanguard
  labels:
    app.kubernetes.io/part-of: vanguard-bot
type: Opaque
stringData:
  # Telegram
  TELEGRAM_BOT_TOKEN: "REPLACE_ME"
  # AI providers
  DEEPSEEK_API_KEY: ""
  GROQ_API_KEY: ""
  ANTHROPIC_API_KEY: ""
  # Webhook
  WEBHOOK_URL: "https://your-domain.example.com"
  # Auth whitelist (comma-separated Telegram user_ids)
  AUTH_WHITELIST: ""
  # Admin Telegram chat_id for watchdog alerts
  ADMIN_CHAT_ID: ""
  # SaaS API
  API_ADMIN_KEY: "REPLACE_ME_random_secret"
  API_DATABASE_URL: "sqlite:////app/data/vanguard_api.db"
  # Stripe (optional)
  STRIPE_WEBHOOK_SECRET: ""
  STRIPE_API_KEY: ""
  STRIPE_PRICE_PRO: ""
  STRIPE_PRICE_ENTERPRISE: ""
